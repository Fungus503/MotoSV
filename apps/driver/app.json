{
  "expo": {
    "name": "MotoSV Driver",
    "slug": "motosv-driver",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "motosv-driver",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#006e2a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.motosv.driver",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "MotoSV necesita tu ubicación para mostrar viajes cercanos y navegar hacia el pasajero."
      }
    },
    "android": {
      "package": "com.motosv.driver",
      "permissions": ["ACCESS_FINE_LOCATION", "ACCESS_COARSE_LOCATION", "ACCESS_BACKGROUND_LOCATION"],
      "adaptiveIcon": {
        "backgroundColor": "#006e2a"
      }
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "MotoSV necesita tu ubicación para navegar hacia pasajeros. Usamos ubicación en segundo plano para mantener la navegación activa." }]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
