# ═══════════════════════════════════════════════════
# MotoSV — API Server Configuration
# ═══════════════════════════════════════════════════
# Copy this file to .env and fill in the values.
# cp .env.example .env

# ─── Supabase ────────────────────────────────────
# Project URL (from Supabase Dashboard > Settings > API)
SUPABASE_URL=https://guwddvudyyxtbbxjzqbx.supabase.co
# Service Role Key (from Supabase Dashboard > Settings > API > service_role)
# ⚠️ NEVER expose this key to clients. Server-side only.
SUPABASE_SERVICE_ROLE_KEY=

# ─── Redis ────────────────────────────────────────
# Connection string for Redis (required for matching worker + rate limiting)
# Local: redis://localhost:6379
# Railway: redis://default:password@host:port
REDIS_URL=redis://localhost:6379

# ─── Server ──────────────────────────────────────
PORT=3000
NODE_ENV=development

# ─── Logging ─────────────────────────────────────
# Levels: trace, debug, info, warn, error, fatal
LOG_LEVEL=info

# ─── Stripe ──────────────────────────────────────
# (Optional — only needed if using Stripe payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── PayPal ──────────────────────────────────────
# (Optional — only needed if using PayPal payments)
PAYPAL_WEBHOOK_ID=

# ─── Wompi ───────────────────────────────────────
# (Optional — only needed if using Wompi payments)
WOMPI_WEBHOOK_SECRET=
